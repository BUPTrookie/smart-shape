# ===== Python 缓存与字节码 =====
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ===== 原始数据（本地管理，不纳入版本管理）=====
Data/

# ===== 算法产物与图表（可由代码重新生成）=====
Output/
charts/

# ===== 产物 CSV（已统一移 Output/，由 Output/ 规则忽略）=====
utils/shape_comparison_summary.csv

# ===== Word 临时/锁文件与 docx 产物（不入库；md 为文档源）=====
*.docx
~$*
~WRL*.tmp

# ===== 日志 =====
*.log

# ===== 历史误产生的畸形垃圾文件（git扫描会报错，忽略；可手动删除）=====
/DataX9600DZ*
/nul

# ===== 嵌入式 git 仓库（独立项目，不作为 submodule 跟踪）=====
/smart_shape/
